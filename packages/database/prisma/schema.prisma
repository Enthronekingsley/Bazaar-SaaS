generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum IdType {
  NATIONAL_ID
  INTERNATIONAL_PASSPORT
}

enum IdStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum KycStatus {
  UNVERIFIED
  PENDING
  VERIFIED
}

enum BusinessType {
  INDIVIDUAL
  COMPANY
  PARTNERSHIP
}

enum StoreStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductStatus {
  DRAFT
  PUBLISHED
}

model User {
  id        String    @id
  email     String    @unique
  image     String?
  kycStatus KycStatus @default(UNVERIFIED)
  createdAt DateTime  @default(now())

  meansOfId MeansOfId?
  store     Store?
}

model MeansOfId {
  id         String   @id @default(cuid())
  userId     String   @unique
  type       IdType
  idNumber   String
  firstName  String
  surname    String
  middleName String?
  status     IdStatus @default(PENDING)
  imageUrl   String
  metadata   Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Store {
  id              String       @id @default(cuid())
  name            String
  slug            String       @unique
  description     String
  email           String
  contact         String
  address         Json
  businessType    BusinessType
  registrationNo  String?
  taxId           String?
  status          StoreStatus  @default(PENDING)
  reason          Json?
  isActive        Boolean      @default(true)
  subdomain       String?
  customDomain    String?
  logo            String
  coverImage      String?
  favicon         String?
  themeColor      String?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  userId          String       @unique

  user     User      @relation(fields: [userId], references: [id])
  products Product[]
}

model Product {
  id                String        @id @default(cuid())
  name              String
  slug              String
  description       String
  mrp               Int
  price             Int
  images            String[]
  status            ProductStatus @default(DRAFT)
  trackInventory    Boolean       @default(true)
  stockQuantity     Int           @default(0)
  lowStockThreshold Int           @default(10)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  storeId           String
  categoryId        String

  store          Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category       Category               @relation(fields: [categoryId], references: [id])
  specifications ProductSpecification[]
  tags           ProductTag[]

  @@unique([storeId, slug])
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  parentId    String?

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([parentId])
}

model ProductSpecification {
  id        String @id @default(cuid())
  key       String
  value     String
  productId String

  product Product @relation(fields: [productId], references: [id])

  @@index([productId])
}

model Tag {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products ProductTag[]

  @@index([isActive])
}

model ProductTag {
  productId  String
  tagId      String
  assignedBy String?
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  tag     Tag     @relation(fields: [tagId], references: [id])

  @@id([productId, tagId])
  @@index([tagId])
  @@index([productId])
}
