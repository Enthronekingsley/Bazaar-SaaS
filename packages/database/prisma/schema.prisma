generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum IdType {
  NATIONAL_ID
  INTERNATIONAL_PASSPORT
}

enum IdStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum KycStatus {
  UNVERIFIED
  PENDING
  VERIFIED
}

enum BusinessType {
  INDIVIDUAL
  COMPANY
  PARTNERSHIP
}

enum StoreStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String    @id
  email     String    @unique
  image     String?
  kycStatus KycStatus @default(UNVERIFIED)
  createdAt DateTime  @default(now())

  meansOfId MeansOfId?
  store     Store?
}

model MeansOfId {
  id         String   @id @default(cuid())
  userId     String   @unique
  type       IdType
  idNumber   String
  firstName  String
  surname    String
  middleName String?
  status     IdStatus @default(PENDING)
  imageUrl   String
  metadata   Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Store {
  id              String       @id @default(cuid())
  name            String
  slug            String       @unique
  description     String
  email           String
  contact         String
  address         Json
  businessType    BusinessType
  registrationNo  String?
  taxId           String?
  status          StoreStatus  @default(PENDING)
  reason          Json?
  isActive        Boolean      @default(true)
  subdomain       String?
  customDomain    String?
  logo            String
  coverImage      String?
  favicon         String?
  themeColor      String?
  metaTitle       String?
  metaDescription String?
  userId          String       @unique
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id])
}
